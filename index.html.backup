    <!-- Timeline Section -->
    <section id="timeline">
        <div class="container">
            <h2>Journey</h2>
            <p class="section-subtitle">Key milestones and achievements</p>
            
            <div class="timeline-container">
                <div class="timeline-line"></div>
                
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <h4>2024 - Present</h4>
                        <p>Principal Engineer at TechCorp, architecting scalable microservices handling 1M+ daily requests.</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <h4>2022 - 2024</h4>
                        <p>Lead Full-Stack Developer, shipped 15+ production applications serving 2M+ users globally.</p>
