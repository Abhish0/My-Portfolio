    <!-- Projects Section -->
    <section id="projects">
        <div class="container">
            <h2>Featured Projects</h2>
            <p class="section-subtitle">High-impact digital solutions</p>
            
            <div class="projects-grid">
                <div class="project-card" data-tilt>
                    <div class="project-image">
                        <i class="fas fa-chart-line"></i>
                    </div>
